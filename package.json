{
  "name": "reviewable-configs",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "bin": {
    "reviewable-upgrade": "./bin/reviewable-upgrade.mjs"
  },
  "scripts": {
    "test": "node --test --test-isolation=none test/reviewable-upgrade.test.js",
    "update": "yarn up -R '*' && yarn dedupe --strategy highest",
    "latest": "yarn npm-check-updates -i -m --packageManager yarn --install never && yarn install"
  },
  "dependencies": {
    "eslint": "^8.57.0 || ^9.12.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-lodash": "^8.0.0",
    "typescript-eslint": "^8.7.0"
  },
  "devDependencies": {
    "npm-check-updates": "^20.0.0"
  }
}
